# 后端环境变量示例（Railway 部署时在平台后台填入真实值）
# 本文件可安全提交到 Git；真实 .env 文件已被 .gitignore 忽略

# ─────────────────────────────────────────────
# PORT：后端监听端口
# ─────────────────────────────────────────────
# 本地开发：可不设，代码默认回退到 3001
# 线上部署：由 Railway 自动注入，无需手动填写（平台分配一个端口）
# PORT=3001

# ─────────────────────────────────────────────
# CLIENT_ORIGIN：线上前端的真实域名（CORS 白名单）
# ─────────────────────────────────────────────
# 本地开发：不设时默认 "*"（允许所有来源，方便联调）
# 线上部署：务必填 Vercel 分配的前端域名，防止其他站点非法调用你的接口
# CLIENT_ORIGIN=https://your-app.vercel.app
CLIENT_ORIGIN=*

# ─────────────────────────────────────────────
# MOCK_FAIL_*：开发环境模拟单平台失败（Day 17）
# ─────────────────────────────────────────────
# 用法：取消注释对应行，模拟该平台抓取失败，测试降级逻辑
# MOCK_FAIL_BILIBILI=1
# MOCK_FAIL_ZHIHU=1
# MOCK_FAIL_DOUYIN=1
